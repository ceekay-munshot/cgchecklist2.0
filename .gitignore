# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# cloudflare / opennext build output (regenerated by `opennextjs-cloudflare build`)
/.open-next/
/.wrangler/

# production
/build

# misc
.DS_Store
*.pem

# harvest CLI / workflow artifact output (generated)
/harvest-report/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but the template MUST be committed
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
