// Prisma schema for the CG Checklist analysis dashboard.
// Flag-based model — there is intentionally NO numeric scoring anywhere.
//
// North stars (see PROJECT_BRIEF.md):
//  1. Acquisition is FULLY AUTOMATED — the analyst supplies only a company;
//     documents are harvested (Screener.in + web research). Manual upload is a
//     DEFERRED fallback (MANUAL_UPLOAD / MANUAL exist but are unused now).
//  2. A run is a LONG-LIVED, RESUMABLE, QUOTA-AWARE batch (free-tier LLMs,
//     daily limits, may span ~5–6 days): hence per-item processing state
//     (ItemResult.status) and per-provider daily usage (ProviderUsage).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime queries go through DATABASE_URL. On Cloudflare/production this is the
  // Prisma Accelerate URL ("prisma://…"); Accelerate can't run migrations, so the
  // Prisma CLI (migrate/db push) uses directUrl — a DIRECT Postgres connection.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// The four flags an evaluated item can resolve to. NEVER a numeric score.
enum Flag {
  GREEN
  RED
  NEUTRAL
  NOT_AVAILABLE
}

enum Exchange {
  NSE
  BSE
}

/// Lifecycle of a (long-lived, resumable) analysis run.
/// PARTIAL = paused, waiting for the next day's free-tier quota.
enum RunStatus {
  QUEUED
  HARVESTING
  HARVESTED // acquisition complete, ready for processing
  PROCESSING
  PARTIAL
  DONE
  ERROR
}

enum SourceDocType {
  SCREENER_PAGE // Tier-1 structured scrape of the Screener.in company page
  ANNUAL_REPORT
  EARNINGS_PDF
  ANNOUNCEMENT
  WEB
  MANUAL_UPLOAD // deferred manual-upload fallback; unused in the primary flow
}

enum FetchedVia {
  SCREENER
  FIRECRAWL
  SCRAPEDO
  DIRECT
  MANUAL // deferred manual-upload fallback; unused in the primary flow
}

enum FetchStatus {
  OK
  EMPTY
  FAILED
}

/// Per-item resumable processing state within a run.
enum ItemStatus {
  PENDING
  PROCESSING
  DONE
  ERROR
  DEFERRED // skipped this pass (e.g. quota exhausted); retried next day
  NEEDS_REVIEW
}

// ---------------------------------------------------------------------------
// Checklist reference data (seeded idempotently from data/checklist.json)
// ---------------------------------------------------------------------------

/// One of the 16 checklist section-blocks.
model ChecklistSection {
  code       String          @id // e.g. "A1"
  name       String
  orderIndex Int             @default(0)
  items      ChecklistItem[]
}

/// One of the 106 governance checklist items. Mirrors data/checklist.json.
model ChecklistItem {
  id              String           @id // JSON item id, e.g. "A1-01"
  section         ChecklistSection @relation(fields: [sectionCode], references: [code], onDelete: Cascade)
  sectionCode     String
  item            String           @db.Text // the question / item text
  description     String?          @db.Text
  outputFormat    String? // output_format (e.g. "Percentage (%)", "Yes/No", "Ratio")
  greenFlag       String?          @db.Text // green_flag
  redFlag         String?          @db.Text // red_flag
  sourceHint      String?          @db.Text // source_hint
  isNonNegotiable Boolean          @default(false) // is_non_negotiable
  thresholdLogic  String?          @db.Text // threshold_logic
  orderIndex      Int              @default(0)

  itemResults ItemResult[]

  @@index([sectionCode])
}

// ---------------------------------------------------------------------------
// Companies & runs
// ---------------------------------------------------------------------------

/// An Indian listed company under analysis. The analyst supplies only this;
/// source documents are harvested automatically (Screener.in + web research).
model Company {
  id           String        @id @default(cuid())
  name         String
  ticker       String?
  exchange     Exchange?
  sector       String?
  cin          String?       @unique // Corporate Identification Number
  screenerUrl  String? // resolved Screener.in company URL
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  analysisRuns AnalysisRun[]

  @@index([name])
  @@index([ticker])
}

/// A long-lived, resumable, quota-aware analysis batch over a company.
model AnalysisRun {
  id              String       @id @default(cuid())
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId       String
  status          RunStatus    @default(QUEUED)
  createdBy       String?
  createdAt       DateTime     @default(now())
  lastProcessedAt DateTime?
  itemsTotal      Int          @default(0)
  itemsDone       Int          @default(0)
  itemsError      Int          @default(0)
  summaryJson     Json?
  sourceDocs      SourceDoc[]
  itemResults     ItemResult[]

  @@index([companyId])
  @@index([status])
}

/// A document harvested for a run (Screener.in / web research / — deferred —
/// a manual upload).
model SourceDoc {
  id             String        @id @default(cuid())
  run            AnalysisRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId          String
  type           SourceDocType
  name           String
  sourceUrl      String
  fetchedVia     FetchedVia
  fetchStatus    FetchStatus   @default(OK)
  storageRef     String? // path / object key to the stored raw file
  pages          Int?
  structuredData Json? // Tier-1: clean typed JSON (financials, shareholding, pledging, …)
  extractedText  String?       @db.Text // Tier-2: durable extracted text (persists for later processing)
  contentHash    String? // sha256 of extracted content — de-dups identical docs (e.g. concall "REC" landing pages) within a run
  note           String? // short human note, especially on EMPTY / FAILED
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  itemResults ItemResult[]

  // one row per (run, url) → re-running a harvest upserts instead of duplicating
  @@unique([runId, sourceUrl])
  @@index([runId])
  @@index([fetchStatus])
  @@index([runId, contentHash])
}

/// The resumable per-item result for one checklist item within one run.
/// There is NO score field — flags only.
model ItemResult {
  id              String        @id @default(cuid())
  run             AnalysisRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId           String
  item            ChecklistItem @relation(fields: [itemId], references: [id])
  itemId          String
  status          ItemStatus    @default(PENDING)
  flag            Flag? // null until evaluated
  verdict         String? // one-liner verdict
  value           String? // extracted value (e.g. "33%", "1.2x")
  evidenceQuote   String?       @db.Text
  sourceDoc       SourceDoc?    @relation(fields: [sourceDocId], references: [id])
  sourceDocId     String?
  sourcePage      Int? // citation page within the source doc (survives text pruning)
  sourceUrl       String? // citation URL (esp. for web-sourced evidence; survives pruning)
  confidence      Float? // model confidence (NOT a governance score)
  isNonNegotiable Boolean       @default(false)
  gatePass        Boolean? // non-negotiable gate outcome (null until evaluated)
  providerUsed    String? // which LLM provider produced this result
  attempts        Int           @default(0)
  lastError       String?       @db.Text
  processedAt     DateTime?
  analystOverride Boolean       @default(false)
  overrideNote    String?       @db.Text
  createdAt       DateTime      @default(now())

  @@unique([runId, itemId])
  @@index([runId])
  @@index([status])
  @@index([flag])
}

// ---------------------------------------------------------------------------
// Free-tier quota tracking
// ---------------------------------------------------------------------------

/// Per-provider, per-day usage so the batch can stay under free-tier limits.
model ProviderUsage {
  id       String   @id @default(cuid())
  provider String
  date     DateTime @db.Date
  requests Int      @default(0)
  tokens   Int      @default(0)

  @@unique([provider, date])
}
