// Prisma schema for the CG Checklist analysis dashboard.
// Flag-based model — there is intentionally NO numeric scoring anywhere.
//
// DATASTORE: Cloudflare D1 (SQLite) via Prisma's driver adapter (@prisma/adapter-d1).
//  - The Worker connects through the D1 BINDING (see wrangler.jsonc); the analysis
//    job (GitHub Actions, Node) connects through the D1 HTTP API. Both use SQLite.
//  - SQLite has no native ENUMs, so the former enum fields are plain String columns
//    (the app already works in string literals — zero code change). Allowed values
//    are documented next to each field. No Postgres-only @db.Text / @db.Date.
//
// North stars (see PROJECT_BRIEF.md):
//  1. Acquisition is FULLY AUTOMATED — the analyst supplies only a company;
//     documents are harvested (Screener.in + web research). Manual upload is a
//     DEFERRED fallback (MANUAL_UPLOAD / MANUAL exist but are unused now).
//  2. A run is a LONG-LIVED, RESUMABLE, QUOTA-AWARE batch (free-tier LLMs,
//     daily limits, may span ~5–6 days): hence per-item processing state
//     (ItemResult.status) and per-provider daily usage (ProviderUsage).

generator client {
  provider = "prisma-client-js"
  // driverAdapters: run Prisma through a driver adapter (PrismaD1 / PrismaD1HTTP,
  // see lib/db.ts). On Cloudflare Workers the client resolves to Prisma's WASM
  // query engine — but ONLY when @prisma/client is kept OUT of the Next bundle
  // via `serverExternalPackages` in next.config.ts (otherwise Turbopack inlines
  // it and the wasm can't be located at runtime). This is the OpenNext-documented
  // setup: https://opennext.js.org/cloudflare/howtos/db
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  // With the D1 driver adapter the runtime connection comes from the adapter (the
  // D1 HTTP API, see lib/db.ts) — this url is ONLY used by the Prisma CLI for local
  // schema work, so it is a static throwaway file. It deliberately does NOT read
  // DATABASE_URL: a leftover Accelerate ("prisma://") value there would conflict
  // with the driver adapter at client construction.
  url      = "file:./prisma/dev.db"
}

// ---------------------------------------------------------------------------
// Former enums — now String columns (SQLite has no native enum). Allowed values:
//   Flag:          GREEN | RED | NEUTRAL | NOT_AVAILABLE
//   Exchange:      NSE | BSE
//   RunStatus:     QUEUED | HARVESTING | HARVESTED | PROCESSING | PARTIAL | DONE | ERROR
//   SourceDocType: SCREENER_PAGE | ANNUAL_REPORT | EARNINGS_PDF | ANNOUNCEMENT | WEB | MANUAL_UPLOAD
//   FetchedVia:    SCREENER | FIRECRAWL | SCRAPEDO | DIRECT | MANUAL
//   FetchStatus:   OK | EMPTY | FAILED
//   ItemStatus:    PENDING | PROCESSING | DONE | ERROR | DEFERRED | NEEDS_REVIEW
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// Checklist reference data (seeded idempotently from data/checklist.json)
// ---------------------------------------------------------------------------

/// One of the 16 checklist section-blocks.
model ChecklistSection {
  code       String          @id // e.g. "A1"
  name       String
  orderIndex Int             @default(0)
  items      ChecklistItem[]
}

/// One of the 106 governance checklist items. Mirrors data/checklist.json.
model ChecklistItem {
  id              String           @id // JSON item id, e.g. "A1-01"
  section         ChecklistSection @relation(fields: [sectionCode], references: [code], onDelete: Cascade)
  sectionCode     String
  item            String // the question / item text
  description     String?
  outputFormat    String? // output_format (e.g. "Percentage (%)", "Yes/No", "Ratio")
  greenFlag       String? // green_flag
  redFlag         String? // red_flag
  sourceHint      String? // source_hint
  isNonNegotiable Boolean          @default(false) // is_non_negotiable
  thresholdLogic  String? // threshold_logic
  orderIndex      Int              @default(0)

  itemResults ItemResult[]

  @@index([sectionCode])
}

// ---------------------------------------------------------------------------
// Companies & runs
// ---------------------------------------------------------------------------

/// An Indian listed company under analysis. The analyst supplies only this;
/// source documents are harvested automatically (Screener.in + web research).
model Company {
  id           String        @id @default(cuid())
  name         String
  ticker       String?
  exchange     String? // NSE | BSE
  sector       String?
  cin          String?       @unique // Corporate Identification Number
  screenerUrl  String? // resolved Screener.in company URL
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  analysisRuns AnalysisRun[]
  munsAnswers  MunsAnswer[]

  @@index([name])
  @@index([ticker])
}

// Company-level cache of MUNS web-research answers, keyed by (company, item).
// Live web research is the dominant source of run-to-run variance: two runs of
// the same company can retrieve different pages and land on different flags. The
// backfill reuses a fresh (< TTL) cached answer instead of re-querying, so repeat
// runs are STABLE; `force` / an expired entry re-researches. Answers are keyed to
// the company (not a run) so they survive across runs.
model MunsAnswer {
  id        String   @id @default(cuid())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  itemId    String // checklist item id, e.g. "A1-05"
  question  String // the exact MUNS question asked (item text + any directive)
  answer    String // the cleaned MUNS answer reused as evidence
  sources   String? // JSON-encoded string[] of citation URLs
  fromDate  String // search window used (YYYY-MM-DD) — for provenance
  toDate    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, itemId])
  @@index([companyId])
}

/// A long-lived, resumable, quota-aware analysis batch over a company.
model AnalysisRun {
  id              String       @id @default(cuid())
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId       String
  status          String       @default("QUEUED") // RunStatus
  createdBy       String?
  createdAt       DateTime     @default(now())
  lastProcessedAt DateTime?
  itemsTotal      Int          @default(0)
  itemsDone       Int          @default(0)
  itemsError      Int          @default(0)
  summaryJson     Json?
  sourceDocs      SourceDoc[]
  itemResults     ItemResult[]

  @@index([companyId])
  @@index([status])
}

/// A document harvested for a run (Screener.in / web research / — deferred —
/// a manual upload).
model SourceDoc {
  id             String      @id @default(cuid())
  run            AnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId          String
  type           String // SourceDocType
  name           String
  sourceUrl      String
  fetchedVia     String // FetchedVia
  fetchStatus    String      @default("OK") // FetchStatus
  storageRef     String? // path / object key to the stored raw file
  pages          Int?
  structuredData Json? // Tier-1: clean typed JSON (financials, shareholding, pledging, …)
  extractedText  String? // Tier-2: durable extracted text (persists for later processing)
  contentHash    String? // sha256 of extracted content — de-dups identical docs (e.g. concall "REC" landing pages) within a run
  note           String? // short human note, especially on EMPTY / FAILED
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  itemResults ItemResult[]

  // one row per (run, url) → re-running a harvest upserts instead of duplicating
  @@unique([runId, sourceUrl])
  @@index([runId])
  @@index([fetchStatus])
  @@index([runId, contentHash])
}

/// The resumable per-item result for one checklist item within one run.
/// There is NO score field — flags only.
model ItemResult {
  id              String        @id @default(cuid())
  run             AnalysisRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId           String
  item            ChecklistItem @relation(fields: [itemId], references: [id])
  itemId          String
  status          String        @default("PENDING") // ItemStatus
  flag            String? // Flag — null until evaluated
  verdict         String? // one-liner verdict
  value           String? // extracted value (e.g. "33%", "1.2x")
  evidenceQuote   String?
  sourceDoc       SourceDoc?    @relation(fields: [sourceDocId], references: [id])
  sourceDocId     String?
  sourcePage      Int? // citation page within the source doc (survives text pruning)
  sourceUrl       String? // citation URL (esp. for web-sourced evidence; survives pruning)
  confidence      Float? // model confidence (NOT a governance score)
  isNonNegotiable Boolean       @default(false)
  gatePass        Boolean? // non-negotiable gate outcome (null until evaluated)
  providerUsed    String? // which LLM provider produced this result
  attempts        Int           @default(0)
  lastError       String?
  processedAt     DateTime?
  analystOverride Boolean       @default(false)
  overrideNote    String?
  createdAt       DateTime      @default(now())

  @@unique([runId, itemId])
  @@index([runId])
  @@index([status])
  @@index([flag])
}

// ---------------------------------------------------------------------------
// Free-tier quota tracking
// ---------------------------------------------------------------------------

/// Per-provider, per-day usage so the batch can stay under free-tier limits.
model ProviderUsage {
  id       String   @id @default(cuid())
  provider String
  date     DateTime // truncated to a day (UTC midnight) by the caller
  requests Int      @default(0)
  tokens   Int      @default(0)

  @@unique([provider, date])
}
