          "is_non_negotiable": false,
          "threshold_logic": ""
        },
        {
          "id": "A1-08",
          "item": "Skills/competence matrix",
          "description": "Maps to strategy, gaps filled",
          "output_format": "Yes/No",
          "green_flag": "Specific, gaps covered",
          "red_flag": "Boilerplate / visible skill gaps",
          "source_hint": "",
          "is_non_negotiable": false,
          "threshold_logic": ""
        },
        {
          "id": "A1-09",
          "item": "ID resignation pattern",
          "description": "Mid-term independent exits",
          "output_format": "Count/Text",
          "green_flag": "None; orderly with clear reasons",
          "red_flag": "≥2 mid-term exits/2yrs or vague \"personal reasons\"",
          "source_hint": "",
          "is_non_negotiable": false,
          "threshold_logic": ""
