  "sections": [
    {
      "code": "A1",
      "name": "Board Structure & Composition",
      "items": [
        {
          "id": "A1-01",
          "item": "Board size & independence ratio",
          "description": "Independent-director share vs LODR minimum",
          "output_format": "% independent",
          "green_flag": "≥50% independent; board 8–12",
          "red_flag": "<50% / only meets bare minimum",
          "source_hint": "",
          "is_non_negotiable": false,
          "threshold_logic": ""
        },
        {
          "id": "A1-02",
          "item": "Chairman–MD separation",
          "description": "Roles split, chairman non-promoter",
          "output_format": "Yes/No",
          "green_flag": "Separated, chairman non-promoter",
          "red_flag": "Same person or promoter holds both",
          "source_hint": "",
          "is_non_negotiable": false,
          "threshold_logic": ""
        },
        {
          "id": "A1-03",
          "item": "Non-executive chairman",
          "description": "Chairman has no executive role",
          "output_format": "Yes/No",
          "green_flag": "Non-executive (ideally independent)",
          "red_flag": "Executive promoter-chairman",
          "source_hint": "",
          "is_non_negotiable": false,
          "threshold_logic": ""
        },
        {
          "id": "A1-04",
          "item": "True independence of IDs",
          "description": "Tenure, ties, fee dependence",
          "output_format": "Score (1–5)",
          "green_flag": "<2 terms, no ties, low fee dependence",
          "red_flag": ">10-yr tenure / ex-employees / material ties",
          "source_hint": "",
          "is_non_negotiable": false,
          "threshold_logic": ""
        },
        {
          "id": "A1-05",
          "item": "Director reputation",
          "description": "Standing across other boards",
          "output_format": "Text/Score",
          "green_flag": "Clean, well-regarded",
          "red_flag": "Linked to past frauds/defaults",
          "source_hint": "",
          "is_non_negotiable": false,
          "threshold_logic": ""
        },
        {
          "id": "A1-06",
          "item": "Overboarding",
          "description": "Directorships held elsewhere",
          "output_format": "Count",
          "green_flag": "≤7 listed boards (≤3 if also ED)",
          "red_flag": "At/over statutory cap or >7–8 boards",
          "source_hint": "",
          "is_non_negotiable": false,
          "threshold_logic": ""
        },
        {
          "id": "A1-07",
          "item": "Attendance records",
