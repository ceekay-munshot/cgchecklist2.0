# ============================================================================
# CG Checklist — environment template
# Copy to `.env` (gitignored) and fill in. NEVER commit real keys.
# ============================================================================

# ---- LLM providers ---------------------------------------------------------
# Gemini — long-context document reading (annual reports, auditor notes)
GEMINI_API_KEY=
# Optional model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Groq — fast/cheap bulk classification across many checklist items
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Mistral — qualitative reasoning + tie-breaks
MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-large-latest

# Nvidia NIM — fallback capacity
NVIDIA_API_KEY=
# NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# ---- Web research (fallback chain: Firecrawl -> Scrape.do) -----------------
FIRECRAWL_API_KEY=
SCRAPEDO_API_KEY=

# ---- Document harvesting (Screener.in) -------------------------------------
# Used by the automated harvester (Playwright). Source these from GitHub
# secrets in CI. The harvester itself lands in Phase 3 — config only for now.
SCREENER_EMAIL=
SCREENER_PASSWORD=

# ---- Database --------------------------------------------------------------
# Postgres connection string used by Prisma.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/cgchecklist?schema=public"
